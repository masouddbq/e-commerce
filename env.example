# Payment Gateway Configuration
# تنظیمات درگاه‌های پرداخت

# زرین‌پال
VITE_ZARINPAL_MERCHANT_ID=your_zarinpal_merchant_id
VITE_ZARINPAL_API_KEY=your_zarinpal_api_key
VITE_ZARINPAL_CALLBACK_URL=http://localhost:3000/payment/callback
VITE_ZARINPAL_SANDBOX=true

# پی‌پینگ
VITE_PAYPING_MERCHANT_ID=your_payping_merchant_id
VITE_PAYPING_API_KEY=your_payping_api_key
VITE_PAYPING_CALLBACK_URL=http://localhost:3000/payment/callback
VITE_PAYPING_SANDBOX=true

# آیدی‌پی
VITE_IDPAY_MERCHANT_ID=your_idpay_merchant_id
VITE_IDPAY_API_KEY=your_idpay_api_key
VITE_IDPAY_CALLBACK_URL=http://localhost:3000/payment/callback
VITE_IDPAY_SANDBOX=true

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_BASE_URL=http://localhost:4000

# OTP Backend (server/.env)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CLIENT_ORIGIN=http://localhost:5173
PORT=4000

# Zarinpal Payment Gateway (server/.env)
ZARINPAL_MERCHANT_ID=your_zarinpal_merchant_id
ZARINPAL_SANDBOX=true

# Faraz SMS Credentials
FARAZ_SMS_API_URL=https://ippanel.com/api/select
FARAZ_SMS_USERNAME=your_faraz_username
FARAZ_SMS_PASSWORD=your_faraz_password
FARAZ_SMS_SENDER_NUMBER=3000xxxxxxx
# اگر از الگو استفاده می‌کنید:
# FARAZ_SMS_PATTERN_CODE=your_pattern_code
# متن پیامک (از {code} برای قرار دادن کد استفاده کنید)
OTP_SMS_TEMPLATE=کد تایید شما: {code}
OTP_EXPIRATION_MINUTES=2
OTP_MAX_PER_HOUR=5
OTP_TABLE_NAME=otp_requests
OTP_EMAIL_DOMAIN=otp.lentshop.local

# App Configuration
VITE_SITE_URL=http://localhost:3000
VITE_SITE_NAME=لنت شاپ

# OTP Configuration (برای غیرفعال کردن OTP موقتاً: VITE_ENABLE_OTP=false)
VITE_ENABLE_OTP=true
